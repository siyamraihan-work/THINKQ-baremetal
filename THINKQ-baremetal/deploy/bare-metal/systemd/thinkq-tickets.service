[Unit]
Description=ThinkQ Tickets Service
After=network-online.target thinkq-data.service
Wants=network-online.target thinkq-data.service

[Service]
Type=simple
WorkingDirectory=/opt/thinkq/backend/tickets-service
EnvironmentFile=/opt/thinkq/env/tickets-service.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/env node src/server.js
Restart=always
RestartSec=5
User=thinkq
Group=thinkq
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
