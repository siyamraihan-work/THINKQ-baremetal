PORT=3001
SERVICE_HOST=127.0.0.1
NODE_ENV=production

DATA_SERVICE_URL=http://127.0.0.1:8080
REDIS_URL=redis://127.0.0.1:6379
INTERNAL_API_KEY=replace-with-one-long-shared-internal-secret

COOKIE_SECURE=true
DEV_AUTH_ENABLED=false
FRONTEND_BASE_URL=https://thinkq.arizona.edu
LOGIN_PATH=/login
UNAUTHORIZED_PATH=/unauthorized
POST_LOGIN_PATH=/

SAML_ENTRY_POINT=https://shibboleth.arizona.edu/idp/profile/SAML2/Redirect/SSO
SAML_IDP_ENTITY_ID=urn:mace:incommon:arizona.edu
SAML_ISSUER=https://thinkq.arizona.edu/auth/metadata
SAML_CALLBACK_URL=https://thinkq.arizona.edu/auth/saml/callback
SAML_CERT_PATH=/opt/thinkq/certs/idp-signing.pem
