[Unit]
Description=ThinkQ Tickets Service
After=network.target redis-server.service thinkq-data.service
Wants=redis-server.service thinkq-data.service

[Service]
Type=simple
WorkingDirectory=/opt/thinkq/work_backend/tickets-service
EnvironmentFile=/opt/thinkq/env/tickets-service.env
ExecStart=/usr/bin/node src/server.js
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
